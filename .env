# START_MODULE_CONTRACT
# PURPOSE: Define the environment contract for Kodex local infrastructure and Phase 1 defaults.
# SCOPE: PostgreSQL, MinIO, authentication, CORS, and feature-flag configuration.
# DEPENDS: docker-compose.yml
# LINKS: M-INFRA-ENV, M-INFRA-COMPOSE, M-CONFIG
# END_MODULE_CONTRACT
# START_MODULE_MAP
# postgres-vars - Database credentials and async connection URL
# minio-vars - Object storage credentials and public addressing
# auth-vars - Prototype admin authentication settings
# cors-vars - Local frontend allowlist
# feature-flags - Phase 1 integration toggles
# END_MODULE_MAP
# PostgreSQL
POSTGRES_USER=kodex
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=kodex_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://kodex:changeme_strong_password@db:5432/kodex_db

# MinIO / S3
MINIO_ROOT_USER=kodex_minio
MINIO_ROOT_PASSWORD=changeme_strong_password
MINIO_BUCKET=kodex-products
MINIO_ENDPOINT=http://s3:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000/kodex-products

# Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password
SECRET_KEY=change-this-to-a-random-64-character-string-before-any-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Feature flags (Phase 1 defaults)
ENABLE_RECOMBEE=false
RECOMBEE_API_KEY=
RECOMBEE_DB_ID=
